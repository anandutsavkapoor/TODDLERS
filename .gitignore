# --- Data WE generate (not committed; regenerated from the committed inputs) ---
# Only products our own pipeline can rebuild are ignored. The pySB99 database
# (pysb99/pySB99_files/*.npy/.txt/.dat, ~151M of raw tracks/spectra/atmosphere
# inputs) IS committed so pySB99 sampling and SED generation work out of the box.
# single_star_tracks.h5 (556M, built by generate_single_star_database)
src/toddlers/database/*.h5
src/toddlers/interpolants/**/hdf5/
# recollapse_data_*.hdf5 etc. (rebuilt from the evolution runs)
*.hdf5

# --- Run outputs ---
evolution_output/
evolution_logs/
cloudy_output/
*.log
*.out

# --- Regenerated example outputs (the inputs/scripts are committed) ---
examples/*.png
examples/**/*.png
examples/paper_figures/figures/
examples/paper_figures/evolution_output/
examples/paper_figures/grain_comparison/*.out
examples/paper_figures/grain_comparison/*.cont
examples/stab/stab_output/
examples/stab/cloud_family_stab_output/
examples/stab/*_interp_tables/
examples/stab/*_sed_output_*/
# (grain_comparison/*.in are committed hand-crafted Cloudy inputs)

# --- Sphinx docs (autogenerated; rebuilt by `make html` / Read the Docs) ---
docs/_build/
# sphinx-apidoc output, regenerated each build by docs/conf.py
docs/api/
